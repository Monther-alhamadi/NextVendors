# ═══════════════════════════════════════════════════════════════
#  E-Commerce Store — Environment Configuration
#  Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=ecommerce-store
DEBUG=false
API_V1_STR=/api/v1

# ── Database ─────────────────────────────────────────────────
# For production, use PostgreSQL:
DATABASE_URL=postgresql://ecommerce_user:STRONG_PASSWORD_HERE@localhost:5432/ecommerce_db
# For local development with SQLite (not recommended for production):
# DATABASE_URL=sqlite:///./dev.db

# ── Security ─────────────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Cookie Settings ──────────────────────────────────────────
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=.yourdomain.com

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URLS=https://yourdomain.com

# ── Redis (Caching & Rate Limiting) ─────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CACHE_TTL_CATALOG=300
CACHE_TTL_CATEGORIES=600
CACHE_TTL_SESSION=3600

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME=E-Commerce Store

# ── Payment Gateway ──────────────────────────────────────────
# Set to your payment provider: stripe, tap, paypal
# PAYMENT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Dropshipping (CJ API) ───────────────────────────────────
CJDROPSHIPPING_API_KEY=your-cj-api-key-here

# ── Social Login ─────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id

# ── Feature Flags ────────────────────────────────────────────
ENABLE_RAPTOR_MINI=true

# ── Tax ──────────────────────────────────────────────────────
DEFAULT_TAX_RATE=0.15
