## Example production environment variables
# Copy this file to `.env.production` and replace placeholder values with secure ones.

# App configuration
APP_NAME="ecommerce-store"
DEBUG=false
ENABLE_RAPTOR_MINI=true

# Database
POSTGRES_DB=app
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Redis (used for rate-limiting and caching)
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET_KEY=replace-with-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=your-domain.com

# Cloudinary (optional: image CDN/hosting)
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Monitoring, logs & error collection (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/backend/app.log
LOG_AGGREGATOR_URL=

# NOTE: Do NOT store secrets in source control. Use a secrets manager in production.
