# استخدام Node.js كصورة أساسية للتطوير
FROM node:18-alpine

# تعيين مجلد العمل
WORKDIR /app

# نسخ ملفات package
COPY package*.json ./

# تثبيت جميع المتطلبات (بما في ذلك dev dependencies)
RUN npm install

# نسخ باقي الملفات
COPY . .

# فتح البورت 5173 (المنفذ الافتراضي لـ Vite)
EXPOSE 5173

# تشغيل خادم التطوير
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
